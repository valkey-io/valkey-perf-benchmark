          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH size_categories AS (\n  SELECT \n    CASE \n      WHEN size <= 42 THEN 1\n      WHEN size <= 84 THEN 2\n      ELSE 3\n    END AS size_bucket,\n    version,\n    value\n  FROM \"mem-efficiency-by-version\"\n)\nSELECT \n  version,\n  AVG(CASE WHEN size_bucket = 1 THEN value END) AS \"Small (8-42)\",\n  AVG(CASE WHEN size_bucket = 2 THEN value END) AS \"Medium (43-84)\",\n  AVG(CASE WHEN size_bucket = 3 THEN value END) AS \"Large (85-128)\"\nFROM size_categories\nGROUP BY version\nORDER BY version",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Avg Bytes of Overhead Per Item - Lower is Better",
