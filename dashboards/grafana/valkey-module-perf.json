          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH runs_per_scenario AS (SELECT scenario, \"group\", config_set::text AS cs, config_name, architecture, commit, module_commit, AVG(rps) AS rps, AVG(p99_latency_ms) AS p99, timestamp, created_at, ROW_NUMBER() OVER (PARTITION BY scenario, \"group\", config_set::text, config_name, architecture ORDER BY timestamp DESC, created_at DESC) AS run_rank FROM benchmark_metrics_search GROUP BY scenario, \"group\", config_set, config_name, architecture, commit, module_commit, timestamp, created_at) SELECT 'search' AS module, l.config_name, l.architecture, l.cs AS config_set, l.\"group\", l.scenario, LEFT(l.commit, 7) AS core_commit, LEFT(l.module_commit, 7) AS module_commit, LEFT(p.commit, 7) AS prev_core_commit, LEFT(p.module_commit, 7) AS prev_module_commit, ROUND(l.rps::numeric, 0) AS latest_rps, ROUND(p.rps::numeric, 0) AS previous_rps, ROUND((l.rps / NULLIF(p.rps, 0))::numeric, 3) AS rps_ratio, ROUND(l.p99::numeric, 3) AS latest_p99, ROUND(p.p99::numeric, 3) AS previous_p99, ROUND((l.p99 / NULLIF(p.p99, 0))::numeric, 3) AS p99_ratio, l.created_at FROM runs_per_scenario l JOIN runs_per_scenario p ON l.scenario = p.scenario AND l.\"group\" = p.\"group\" AND l.cs = p.cs AND l.config_name = p.config_name AND l.architecture = p.architecture WHERE l.run_rank = 1 AND p.run_rank = 2 AND (l.rps / NULLIF(p.rps, 0) < 0.99 OR l.p99 / NULLIF(p.p99, 0) > 1.01) ORDER BY l.created_at DESC, rps_ratio ASC",
          "refId": "A"
        }
      ],
      "title": "Regression Detection (RPS < 99% or p99 > 101% of previous run)",
      "type": "table"
    }
