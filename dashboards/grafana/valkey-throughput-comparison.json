          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  commit AS version,\n  AVG(CASE \n        WHEN data_size = 512 AND io_threads = 1 AND pipeline = 1 \n        THEN rps \n      END) AS \"512B , IO 1, P 1\",\n  AVG(CASE \n        WHEN data_size = 512 AND io_threads = 1 AND pipeline = 10 \n        THEN rps \n      END) AS \"512B, IO 1, P 10\",\n  AVG(CASE \n      WHEN data_size = 512 AND io_threads = 9 AND pipeline = 1\n      THEN rps \n    END) AS \"512B , IO 9, P 1\",\n  AVG(CASE \n        WHEN data_size = 512 AND io_threads = 9 AND pipeline = 10 \n        THEN rps \n      END) AS \"512B , IO 9, P 10\"\nFROM benchmark_tags_metrics\nWHERE command = 'SET'\n  AND data_size = 512\n  AND io_threads IN (1, 9)\n  AND pipeline IN (1, 10)\nGROUP BY commit\nORDER BY commit;",
          "refId": "A",
